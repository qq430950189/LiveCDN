# Build stage
ARG GO_VERSION=1.26.2
FROM golang:${GO_VERSION}-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /controller ./cmd/controller

# Runtime stage
FROM alpine:3.19

RUN apk --no-cache add ca-certificates tzdata
WORKDIR /app
COPY --from=builder /controller /usr/local/bin/controller
COPY deploy/install.sh /app/deploy/install.sh
RUN chmod 0755 /app/deploy/install.sh && mkdir -p /app/binaries

EXPOSE 8080
ENTRYPOINT ["controller"]
CMD ["-config", "/app/configs/controller.yaml"]
