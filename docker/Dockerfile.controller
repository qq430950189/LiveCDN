# Build stage
FROM golang:1.22-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /controller ./cmd/controller

# Runtime stage
FROM alpine:3.19

RUN apk --no-cache add ca-certificates tzdata
COPY --from=builder /controller /usr/local/bin/controller

EXPOSE 8080
ENTRYPOINT ["controller"]
CMD ["-config", "/app/configs/controller.yaml"]
