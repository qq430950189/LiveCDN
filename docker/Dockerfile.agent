# Intentionally unsupported.
#
# LiveCDN edge Agents are deployed as a single musl static binary on bare-metal
# NAT/low-end hosts and managed by systemd via deploy/install.sh. Do not build
# or run edge Agents as Docker containers; doing so does not match the project
# deployment model and hides the real network/NAT behavior that must be tested.
#
# This stub is kept only to make stale CI/scripts fail with an explicit message
# instead of silently producing an unsupported Agent image.
FROM alpine:3.19
RUN echo 'ERROR: Docker-based edge Agent deployment is unsupported. Use ./deploy/build-binaries.sh and deploy/install.sh on the target host.' >&2 && false
